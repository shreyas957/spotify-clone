{
  "AWSEBDockerrunVersion": 2,
  "volumes": [
    {
      "name": "mysql-data",
      "host": { "sourcePath": "/var/lib/mysql" }
    },
    {
      "name": "mongo-data",
      "host": { "sourcePath": "/var/lib/mongo" }
    },
    {
      "name": "redis-data",
      "host": { "sourcePath": "/var/lib/redis" }
    }
  ],
  "containerDefinitions": [
    {
      "name": "config-server",
      "image": "spotify-config-server:latest",
      "essential": true,
      "memory": 512,
      "portMappings": [{ "hostPort": 8888, "containerPort": 8888 }],
      "environment": []
    },
    {
      "name": "eureka-server",
      "image": "spotify-eureka-server:latest",
      "essential": true,
      "memory": 512,
      "portMappings": [{ "hostPort": 8761, "containerPort": 8761 }],
      "environment": [
        { "name": "CONFIG_SERVER_URL", "value": "http://config-server:8888" },
        { "name": "EUREKA_SERVICE_HOSTNAME", "value": "eureka-server" },
        { "name": "EUREKA_DEFAULT_ZONE_URL", "value": "http://eureka-server:8761/eureka/" }
      ]
    },
    {
      "name": "api-gateway",
      "image": "spotify-api-gateway:latest",
      "essential": true,
      "memory": 512,
      "portMappings": [{ "hostPort": 9090, "containerPort": 9090 }],
      "environment": [
        { "name": "EUREKA_SERVICE_HOSTNAME", "value": "eureka-server" },
        { "name": "EUREKA_DEFAULT_ZONE_URL", "value": "http://eureka-server:8761/eureka/" },
        { "name": "CONFIG_SERVER_URL", "value": "http://config-server:8888" },
        { "name": "FRONTEND_URL", "value": "http://localhost:4300" },
        { "name": "USER_SERVICE_HOST", "value": "http://user-service:8001" },
        { "name": "AUTH_SERVICE_HOST", "value": "http://auth-service:8002" },
        { "name": "MUSIC_SERVICE_HOST", "value": "http://music-service:8003" },
        { "name": "WISHLIST_SERVICE_HOST", "value": "http://wishlist-service:8004" },
        { "name": "AI_LLM_CHAT_SERVICE_HOST", "value": "http://ai-chat-service:8005" }
      ]
    },
    {
      "name": "user-service",
      "image": "spotify-user-service:latest",
      "essential": true,
      "memory": 512,
      "portMappings": [{ "hostPort": 8001, "containerPort": 8001 }],
      "environment": [
        { "name": "SPRING_DATASOURCE_URL", "value": "jdbc:mysql://mysql:3306/user" },
        { "name": "SPRING_DATASOURCE_USERNAME", "value": "root" },
        { "name": "SPRING_DATASOURCE_PASSWORD", "value": "12345" },
        { "name": "KAFKA_SERVER_URL", "value": "kafka:9092" },
        { "name": "EUREKA_SERVICE_HOSTNAME", "value": "eureka-server" },
        { "name": "EUREKA_DEFAULT_ZONE_URL", "value": "http://eureka-server:8761/eureka/" },
        { "name": "CONFIG_SERVER_URL", "value": "http://config-server:8888" }
      ]
    },
    {
      "name": "auth-service",
      "image": "spotify-auth-service:latest",
      "essential": true,
      "memory": 512,
      "portMappings": [{ "hostPort": 8002, "containerPort": 8002 }],
      "environment": [
        { "name": "SPRING_DATASOURCE_URL", "value": "jdbc:mysql://mysql:3306/auth" },
        { "name": "SPRING_DATASOURCE_USERNAME", "value": "root" },
        { "name": "SPRING_DATASOURCE_PASSWORD", "value": "12345" },
        { "name": "KAFKA_SERVER_URL", "value": "kafka:9092" },
        { "name": "EUREKA_SERVICE_HOSTNAME", "value": "eureka-server" },
        { "name": "EUREKA_DEFAULT_ZONE_URL", "value": "http://eureka-server:8761/eureka/" },
        { "name": "CONFIG_SERVER_URL", "value": "http://config-server:8888" },
        { "name": "USER_SERVICE_HOST", "value": "http://user-service:8001" }
      ]
    },
    {
      "name": "music-service",
      "image": "spotify-music-service:latest",
      "essential": true,
      "memory": 512,
      "portMappings": [{ "hostPort": 8003, "containerPort": 8003 }],
      "environment": [
        { "name": "SPRING_DATASOURCE_URL", "value": "jdbc:mysql://mysql:3306/music" },
        { "name": "SPRING_DATASOURCE_USERNAME", "value": "root" },
        { "name": "SPRING_DATASOURCE_PASSWORD", "value": "12345" },
        { "name": "SPOTIFY_CLIENT_ID", "value": "" },
        { "name": "SPOTIFY_CLIENT_SECRET", "value": "" },
        { "name": "KAFKA_SERVER_URL", "value": "kafka:9092" },
        { "name": "EUREKA_SERVICE_HOSTNAME", "value": "eureka-server" },
        { "name": "EUREKA_DEFAULT_ZONE_URL", "value": "http://eureka-server:8761/eureka/" },
        { "name": "CONFIG_SERVER_URL", "value": "http://config-server:8888" }
      ]
    },
    {
      "name": "wishlist-service",
      "image": "spotify-wishlist-service:latest",
      "essential": true,
      "memory": 512,
      "portMappings": [{ "hostPort": 8004, "containerPort": 8004 }],
      "environment": [
        { "name": "CONFIG_SERVER_URL", "value": "http://config-server:8888" },
        { "name": "SPRING_DATA_MONGODB_URI", "value": "mongodb://mongodb:27017/wishlist" },
        { "name": "REDIS_HOST", "value": "redis" },
        { "name": "REDIS_PORT", "value": "6379" },
        { "name": "EUREKA_SERVICE_HOSTNAME", "value": "eureka-server" },
        { "name": "EUREKA_DEFAULT_ZONE_URL", "value": "http://eureka-server:8761/eureka/" },
        { "name": "MUSIC_SERVICE_HOST", "value": "http://music-service:8003" }
      ]
    },
    {
      "name": "ai-chat-service",
      "image": "spotify-ai-chat-server:latest",
      "essential": true,
      "memory": 512,
      "portMappings": [{ "hostPort": 8005, "containerPort": 8005 }],
      "environment": [
        { "name": "GEMINI_API_KEY", "value": "" },
        { "name": "OLLAMA_BASE_URL", "value": "http://host.docker.internal:11434" },
        { "name": "KAFKA_SERVER_URL", "value": "kafka:9092" },
        { "name": "EUREKA_SERVICE_HOSTNAME", "value": "eureka-server" },
        { "name": "EUREKA_DEFAULT_ZONE_URL", "value": "http://eureka-server:8761/eureka/" },
        { "name": "CONFIG_SERVER_URL", "value": "http://config-server:8888" }
      ]
    },
    {
      "name": "mysql",
      "image": "mysql",
      "essential": false,
      "memory": 512,
      "portMappings": [{ "hostPort": 3306, "containerPort": 3306 }],
      "mountPoints": [{ "sourceVolume": "mysql-data", "containerPath": "/var/lib/mysql" }],
      "environment": [
        { "name": "MYSQL_ROOT_PASSWORD", "value": "12345" },
        { "name": "MYSQL_DATABASE", "value": "user" }
      ]
    },
    {
      "name": "mongodb",
      "image": "mongo",
      "essential": false,
      "memory": 512,
      "portMappings": [{ "hostPort": 27017, "containerPort": 27017 }],
      "mountPoints": [{ "sourceVolume": "mongo-data", "containerPath": "/data/db" }],
      "environment": [
        { "name": "MONGO_INITDB_DATABASE", "value": "wishlist" }
      ]
    },
    {
      "name": "redis",
      "image": "redis",
      "essential": false,
      "memory": 512,
      "portMappings": [{ "hostPort": 6379, "containerPort": 6379 }],
      "mountPoints": [{ "sourceVolume": "redis-data", "containerPath": "/data" }]
    },
    {
      "name": "zookeeper",
      "image": "confluentinc/cp-zookeeper:7.4.0",
      "essential": false,
      "memory": 512,
      "portMappings": [{ "hostPort": 2181, "containerPort": 2181 }],
      "environment": [
        { "name": "ZOOKEEPER_CLIENT_PORT", "value": "2181" },
        { "name": "ZOOKEEPER_TICK_TIME", "value": "2000" }
      ]
    },
    {
      "name": "kafka",
      "image": "confluentinc/cp-kafka:7.4.0",
      "essential": false,
      "memory": 512,
      "portMappings": [{ "hostPort": 9092, "containerPort": 9092 }],
      "environment": [
        { "name": "KAFKA_BROKER_ID", "value": "1" },
        { "name": "KAFKA_ZOOKEEPER_CONNECT", "value": "zookeeper:2181" },
        { "name": "KAFKA_ADVERTISED_LISTENERS", "value": "PLAINTEXT://kafka:9092" },
        { "name": "KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR", "value": "1" }
      ]
    }
  ]
}
